ax3.set_title(f'Dwarf membership probability (f={best_f:.2f})')
plt.colorbar(scatter, ax=ax3, label='P(dwarf)')
ax3.grid(True, alpha=0.3)
ax3.axis('equal')

ax4 = axes[1, 0]


x_grid = np.linspace(x_pc.min() - 200, x_pc.max() + 200, 100)
y_grid = np.linspace(y_pc.min() - 200, y_pc.max() + 200, 100)
X_grid, Y_grid = np.meshgrid(x_grid, y_grid)

X_rot_grid = X_grid * best_cosa + Y_grid * best_sina
Y_rot_grid = Y_grid * best_cosa - X_grid * best_sina
Z_grid = (1/(2*np.pi*best_sigma_x*best_sigma_y)) * np.exp(
    -0.5 * (((X_rot_grid - best_xc)/best_sigma_x)**2 + 
            ((Y_rot_grid - best_yc)/best_sigma_y)**2)
